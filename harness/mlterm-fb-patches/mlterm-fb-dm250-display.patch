 static inline u_char *get_fb(int x, int y) {
+  /*
+   * Every framebuffer access computes its address through get_fb(), so this is
+   * the single choke point for marking the deferred-flush shadow dirty. Marking
+   * on reads too (e.g. get_pixel2) only causes a rare, harmless extra flush;
+   * missing a write would leave stale pixels, so we err toward over-flushing.
+   * Cheap no-op when not shadowed (real_fb == NULL).
+   */
+  _display.fb_dirty = 1;
   return _display.fb + (_display.yoffset + y) * _display.line_length +
          (_display.xoffset + x) * _display.bytes_per_pixel / _display.pixels_per_byte;
 }
@@ -1271,7 +1279,13 @@
       close(_display.fd);
     }
 
-    munmap(_display.fb, _display.smem_len);
+    if (_display.real_fb) {
+      /* fb is the malloc'd shadow; real_fb is the mmap'd hardware framebuffer. */
+      free(_display.fb);
+      munmap(_display.real_fb, _display.smem_len);
+    } else {
+      munmap(_display.fb, _display.smem_len);
+    }
     teardown_mark("TEARDOWN: post-munmap\n");
     close(_display.fb_fd);
     teardown_mark("TEARDOWN: done\n");
@@ -1373,6 +1387,25 @@
   }
 
   return 0;
+}
+
+/*
+ * Deferred-flush of the shadow buffer: blit the RAM shadow to the real (mmap'd)
+ * hardware framebuffer in a single sequential memcpy. Called once per event-loop
+ * iteration before select() (NEED_DISPLAY_SYNC_EVERY_TIME) and from
+ * interrupt_vt100_cmd() to forcibly reflect long output. No-op unless shadowing
+ * is active (>= 8bpp) and something was drawn since the last flush.
+ *
+ * This is what turns a full-screen redraw (e.g. an OSC 5379 font size change)
+ * from thousands of scattered live-framebuffer writes into one clean memcpy,
+ * removing both the input flicker and the rkdrm write-storm that hung the
+ * console on resize.
+ */
+void ui_display_sync(ui_display_t *disp) {
+  if (_display.real_fb && _display.fb_dirty) {
+    memcpy(_display.real_fb, _display.fb, _display.smem_len);
+    _display.fb_dirty = 0;
+  }
 }
 
 void ui_display_idling(ui_display_t *disp) {
--- a/uitoolkit/fb/ui_display_wscons.c
+++ b/uitoolkit/fb/ui_display_wscons.c
@@ -515,6 +515,24 @@
   if (_display.pixels_per_byte > 1 && !(_display.back_fb = malloc(_display.smem_len))) {
     goto error;
   }
+
+  /*
+   * For >= 8bpp (truecolor) framebuffers, where back_fb above is not allocated,
+   * set up a deferred-flush shadow: all drawing is redirected to a RAM buffer
+   * via _display.fb, and ui_display_sync() blits it to the real framebuffer
+   * once per event-loop iteration. If malloc fails we leave _display.fb pointing
+   * at the mmap'd framebuffer and fall back to the original direct rendering.
+   */
+  if (_display.pixels_per_byte == 1) {
+    unsigned char *shadow;
+
+    if ((shadow = malloc(_display.smem_len))) {
+      memcpy(shadow, _display.fb, _display.smem_len);
+      _display.real_fb = _display.fb;
+      _display.fb = shadow;
+      _display.fb_dirty = 0;
+    }
+  }
 #endif
 
